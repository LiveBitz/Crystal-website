generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductSection {
  BESTSELLER
  NEW_ARRIVAL
}

model Product {
  id            String         @id @default(cuid())
  name          String
  imageUrl      String?
  price         Int
  originalPrice Int?
  rating        Int            @default(5)
  reviews       Int            @default(0)
  section       ProductSection
  order         Int            @default(0)
  active        Boolean        @default(true)
  categories    Category[]     @relation("ProductCategories")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([section, active, order])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  order     Int       @default(0)
  active    Boolean   @default(true)
  products  Product[] @relation("ProductCategories")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([active, order])
}

model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

model ComboBanner {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  quote     String
  product   String
  rating    Int      @default(5)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  excerpt     String
  imageUrl    String?
  author      String   @default("Crystalenii")
  publishedAt DateTime @default(now())
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, order])
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}
